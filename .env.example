# AI Judge (primary provider — required)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (fallback judge + Vision Board image generation — optional)
OPENAI_API_KEY=sk-...

# Google OAuth (required for login)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# NextAuth (required — generate with: openssl rand -base64 32)
AUTH_SECRET=...

# Supabase (required — find these in your Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Admin dashboard access (optional — comma-separated emails)
ADMIN_EMAILS=you@example.com

# Sentry (optional — for source map uploads in CI/Vercel)
SENTRY_AUTH_TOKEN=sntrys_...
